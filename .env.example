# =====================================================================
# Variáveis de ambiente — copie este arquivo para .env.local e preencha.
# NUNCA commite o .env.local. Os valores vêm do painel do Supabase.
# =====================================================================

# URL pública do projeto Supabase (Project Settings > Data API)
NEXT_PUBLIC_SUPABASE_URL="https://SEU-PROJETO.supabase.co"

# Chave publicável (publishable / anon) — pode ir para o navegador
NEXT_PUBLIC_SUPABASE_ANON_KEY="sb_publishable_xxxxxxxxxxxxxxxxxxxx"

# Chave secreta (service_role / secret) — USO EXCLUSIVO NO SERVIDOR.
# Jamais prefixe com NEXT_PUBLIC_ e jamais use em Client Components.
SUPABASE_SERVICE_ROLE_KEY="sb_secret_xxxxxxxxxxxxxxxxxxxx"

# URL base da aplicação (usada em links de e-mail/redirect)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ---------------------------------------------------------------------
# Rate limiting (Upstash Redis) — protege login/cadastro/recuperação.
# Valores na aba "REST API" do database no painel da Upstash.
# O TOKEN é secreto: USO EXCLUSIVO NO SERVIDOR, sem prefixo NEXT_PUBLIC_.
# Se ausentes, o rate limiting é desativado (fail-open) — ok em dev.
# ---------------------------------------------------------------------
UPSTASH_REDIS_REST_URL="https://SEU-DB.upstash.io"
UPSTASH_REDIS_REST_TOKEN="xxxxxxxxxxxxxxxxxxxx"
